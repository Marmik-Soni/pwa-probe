# ── .env (shared secrets — never committed) ───────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Database (Drizzle direct connection)
DATABASE_URL=

# ── .env.development (auto-loaded by Next.js in dev) ──────────────────────────
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── .env.production (auto-loaded by Next.js in prod) ─────────────────────────
# NEXT_PUBLIC_APP_URL=https://pwa-probe.vercel.app
